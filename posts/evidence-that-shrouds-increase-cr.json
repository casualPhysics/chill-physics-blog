_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F30f7455b-57aa-4539-b8cd-83c2a2bbc29d_651x151.png 424w, https://substackcdn.com/image/fetch/$s_!KWQW!,w_848,c_limit,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F30f7455b-57aa-4539-b8cd-83c2a2bbc29d_651x151.png 848w, https://substackcdn.com/image/fetch/$s_!KWQW!,w_1272,c_limit,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F30f7455b-57aa-4539-b8cd-83c2a2bbc29d_651x151.png 1272w, https://substackcdn.com/image/fetch/$s_!KWQW!,w_1456,c_limit,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F30f7455b-57aa-4539-b8cd-83c2a2bbc29d_651x151.png 1456w\" sizes=\"100vw\"><img src=\"https://substackcdn.com/image/fetch/$s_!KWQW!,w_1456,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F30f7455b-57aa-4539-b8cd-83c2a2bbc29d_651x151.png\" width=\"651\" height=\"151\" data-attrs=\"{&quot;src&quot;:&quot;https://substack-post-media.s3.amazonaws.com/public/images/30f7455b-57aa-4539-b8cd-83c2a2bbc29d_651x151.png&quot;,&quot;srcNoWatermark&quot;:null,&quot;fullscreen&quot;:null,&quot;imageSize&quot;:null,&quot;height&quot;:151,&quot;width&quot;:651,&quot;resizeWidth&quot;:null,&quot;bytes&quot;:20262,&quot;alt&quot;:null,&quot;title&quot;:null,&quot;type&quot;:&quot;image/png&quot;,&quot;href&quot;:null,&quot;belowTheFold&quot;:true,&quot;topImage&quot;:false,&quot;internalRedirect&quot;:&quot;https://chillphysicsenjoyer.substack.com/i/175502779?img=https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F30f7455b-57aa-4539-b8cd-83c2a2bbc29d_651x151.png&quot;,&quot;isProcessing&quot;:false,&quot;align&quot;:null,&quot;offset&quot;:false}\" class=\"sizing-normal\" alt=\"\" srcset=\"https://substackcdn.com/image/fetch/$s_!KWQW!,w_424,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F30f7455b-57aa-4539-b8cd-83c2a2bbc29d_651x151.png 424w, https://substackcdn.com/image/fetch/$s_!KWQW!,w_848,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F30f7455b-57aa-4539-b8cd-83c2a2bbc29d_651x151.png 848w, https://substackcdn.com/image/fetch/$s_!KWQW!,w_1272,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F30f7455b-57aa-4539-b8cd-83c2a2bbc29d_651x151.png 1272w, https://substackcdn.com/image/fetch/$s_!KWQW!,w_1456,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F30f7455b-57aa-4539-b8cd-83c2a2bbc29d_651x151.png 1456w\" sizes=\"100vw\" loading=\"lazy\"></picture><div></div></div></a></figure></div><p>So interestingly, I\u2019ve almost <strong>doubled the clean air rate</strong> of my CR box fan by shrouding it. This is surprising, and raises some alarm bells. </p><p>At this point, I\u2019m pretty interested to see if I can</p><ul><li><p>Use shrouding on cheaper fans to now get this thing really quiet and really cheap.</p></li><li><p>Use vacuum filters instead of the more expensive MERV 13 ones. </p></li><li><p>Figure out how to nebulise salts with actual particle counters. </p></li><li><p>I also want to figure out a way to make the filters replaceable, perhaps with a cardboard frame. </p></li></ul><p>I also need to buy more equipment, like an anemometer to better characterise the airflows. </p>",
  "truncated_body_text": "A shroud is often used with Corsi-Rosenthal boxes to increase efficiency. The shroud is a piece of cardboard, with a cutout 15\u2019 circle in the middle that is stuck to the top.",
